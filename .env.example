# Cloudflare R2 configuration
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxx
CLOUDFLARE_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_BUCKETNAME=xxxxxxxxxxxx
# Region is often 'auto' for R2. Use your nearest region if needed.
CLOUDFLARE_REGION=auto

# Optional: Use a public base URL to link files directly instead of signed URLs
# Example: https://cdn.example.com or https://<accountid>.r2.dev/<bucket>
CLOUDFLARE_BUCKET_URL=https://xxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com/storages

# Signed URL expiry in seconds (default 900)
URL_TTL_SECONDS=900

# Simple bearer auth token for API (set a strong random value)
APP_PASSWORD=xxxxxxxxxxxxx

# Development-only convenience for calling APIs from the browser.
# NOTE: For open-source dev use; not recommended for production builds.
NEXT_PUBLIC_APP_PASSWORD=xxxxxxxxxxxxx

# Public URL of your thumbnail Worker (e.g., https://thumbs.example.com/thumb)
# If set, image previews use this Worker instead of loading originals.
NEXT_PUBLIC_THUMBNAIL_URL=

# Public url 
NEXT_PUBLIC_CLOUDFLARE_BUCKET_URL_PUBLIC=https://pub-xxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Cloudflare API Token (cho R2 usage/quota) - tạo tại Cloudflare Dashboard > API Tokens, quyền R2 read
# Khác với CLOUDFLARE_ACCESS_KEY (S3 credentials)
CLOUDFLARE_API_TOKEN=

# Hạn mức storage (GB) để hiển thị progress bar, mặc định 10 (R2 free tier)
NEXT_PUBLIC_R2_STORAGE_LIMIT_GB=10